{
	"$schema": "node_modules/oxfmt/configuration_schema.json",
	"printWidth": 120,
	"arrowParens": "always",
	"bracketSameLine": true,
	"bracketSpacing": true,
	"jsxSingleQuote": false,
	"objectWrap": "preserve",
	"quoteProps": "as-needed",
	"semi": false,
	"sortImports": {
		"groups": ["builtin", "external", "internal", "parent", "sibling", "index"]
	},
	"singleQuote": true,
	"trailingComma": "es5"
}
